# Reseñas reales de Google (sección de opiniones)
# Copiá este archivo a ".env" y completá los valores. NO se commitea (.gitignore).
#
# 1) GOOGLE_MAPS_API_KEY: API key de Google Cloud con "Places API" habilitada
#    y facturación (billing) activa. Restringila por API y, en prod, por referer/IP.
# 2) GOOGLE_PLACE_ID: identificador del local en Google. Se puede autodetectar con:
#       node scripts/find-place-id.mjs
#    (usa la GOOGLE_MAPS_API_KEY de tu .env)

GOOGLE_MAPS_API_KEY=
GOOGLE_PLACE_ID=
