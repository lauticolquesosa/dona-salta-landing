---
import WhatsAppButton from "./ui/WhatsAppButton.astro";
import { wa } from "../data/site";
---

<section class="relative overflow-hidden bg-terracota text-crema">
  <!-- Textura cálida sutil sobre el color pleno -->
  <div
    class="absolute inset-0 opacity-30 [background:radial-gradient(120%_120%_at_0%_0%,rgba(200,137,59,0.5),transparent_55%),radial-gradient(120%_120%_at_100%_100%,rgba(110,34,51,0.6),transparent_55%)]"
    aria-hidden="true"
  >
  </div>
  <div class="guarda absolute inset-x-0 top-0 opacity-60" aria-hidden="true"></div>

  <div
    class="relative mx-auto max-w-3xl px-4 py-20 text-center sm:px-6 sm:py-28"
  >
    <p data-reveal class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-crema/80">
      Tu lugar en Salta
    </p>
    <h2 data-reveal class="text-3xl font-semibold leading-tight sm:text-5xl">
      Tu mesa en el mejor sabor salteño te espera
    </h2>
    <p data-reveal class="mx-auto mt-5 max-w-xl text-base text-crema/90 sm:text-lg">
      Reservá en segundos por WhatsApp y asegurate tu lugar. Sin vueltas, sin
      esperas: solo buena comida del norte.
    </p>
    <div data-reveal class="mt-9 flex justify-center">
      <WhatsAppButton href={wa.reserva} label="Reservá por WhatsApp" variant="onColor" size="lg" />
    </div>
  </div>
</section>
