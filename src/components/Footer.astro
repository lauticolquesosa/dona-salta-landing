---
import Logo from "./ui/Logo.astro";
import { business, social, navLinks, hoursSummary, credit } from "../data/site";

const year = new Date().getFullYear();

const socials = [
  { label: "Instagram", url: social.links.instagram, handle: social.instagramHandle },
  { label: "Facebook", url: social.links.facebook, handle: "Doña Salta" },
  { label: "TripAdvisor", url: social.links.tripadvisor, handle: "Travelers' Choice 2025" },
].filter((s) => s.url && !s.url.startsWith("["));

const showCredit = credit.agency && !credit.agency.startsWith("[");
---

<footer class="bg-tostado-800 text-crema/80">
  <div class="guarda" aria-hidden="true"></div>
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <!-- Marca -->
      <div class="lg:col-span-2">
        <Logo class="text-crema" />
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-crema/70">
          Cocina regional salteña auténtica en el corazón de {business.address.city}.
          Empanadas a cuchillo, locro, asado y vinos de altura.
        </p>
        <p class="mt-4 text-sm">
          <span class="text-ocre-300">★ {social.googleRating}</span> ·
          {social.googleReviews} reseñas · 🏆 Travelers' Choice 2025
        </p>
      </div>

      <!-- Navegación -->
      <nav aria-label="Pie de página">
        <h3 class="font-semibold text-crema">Explorá</h3>
        <ul class="mt-4 space-y-2 text-sm">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href} class="text-crema/70 underline-offset-4 transition-colors hover:text-crema hover:underline">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Contacto -->
      <div>
        <h3 class="font-semibold text-crema">Visitanos</h3>
        <ul class="mt-4 space-y-2 text-sm text-crema/70">
          <li>{business.address.street}, {business.address.city}</li>
          <li>{hoursSummary}</li>
          <li>
            <a href={`tel:${business.phoneHref}`} class="underline-offset-4 hover:text-crema hover:underline">
              {business.phoneDisplay}
            </a>
          </li>
          <li>
            <a href={`mailto:${business.email}`} class="underline-offset-4 hover:text-crema hover:underline">
              {business.email}
            </a>
          </li>
        </ul>

        {
          socials.length > 0 && (
            <ul class="mt-5 flex flex-wrap gap-3">
              {socials.map((s) => (
                <li>
                  <a
                    href={s.url}
                    target="_blank"
                    rel="noopener"
                    aria-label={`${s.label}: ${s.handle}`}
                    class="inline-flex items-center gap-1.5 rounded-full bg-crema/10 px-3 py-1.5 text-xs font-medium text-crema/90 transition-colors hover:bg-crema/20"
                  >
                    {s.label}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-3 border-t border-crema/10 pt-6 text-xs text-crema/55 sm:flex-row">
      <p>© {year} {business.name}. Todos los derechos reservados.</p>
      {
        showCredit && (
          <p>
            Hecho por{" "}
            <a href={credit.url} target="_blank" rel="noopener" class="underline-offset-4 hover:text-crema hover:underline">
              {credit.agency}
            </a>
          </p>
        )
      }
    </div>
  </div>
</footer>
