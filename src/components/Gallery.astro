---
import SectionHeading from "./ui/SectionHeading.astro";
import { gallery } from "../data/site";

const spanClass = (span?: string) =>
  span === "wide"
    ? "sm:col-span-2"
    : span === "tall"
      ? "row-span-2"
      : "";
---

<section id="galeria" class="scroll-mt-20 bg-crema py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      kicker="Galería"
      title="Pasá, mirá y dejá que te dé hambre"
      subtitle="Platos, ambiente y los detalles que hacen de cada visita un momento."
    />

    <div
      class="mt-12 grid auto-rows-[180px] grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4"
    >
      {
        gallery.map((item, i) => (
          <button
            type="button"
            data-reveal
            data-lightbox
            data-src={item.src}
            data-alt={item.alt}
            class:list={[
              "group relative overflow-hidden rounded-[var(--radius-card)] border border-[var(--color-linea)] shadow-[var(--shadow-warm-sm)] transition-[transform,box-shadow] duration-300 ease-[var(--ease-warm)] hover:shadow-[var(--shadow-warm-md)] focus-visible:outline-offset-4",
              spanClass(item.span),
            ]}
          >
            <img
              src={item.src}
              alt={item.alt}
              width="800"
              height="800"
              loading="lazy"
              decoding="async"
              style={item.objectPosition ? `object-position:${item.objectPosition}` : undefined}
              class="photo h-full w-full object-cover transition-transform duration-500 ease-[var(--ease-warm)] group-hover:scale-105"
            />
            <span class="pointer-events-none absolute inset-0 bg-tostado/0 transition-colors duration-300 group-hover:bg-tostado/20" />
            <span class="pointer-events-none absolute bottom-3 right-3 flex h-9 w-9 items-center justify-center rounded-full bg-crema/90 text-tostado opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" />
              </svg>
            </span>
            <span class="sr-only">Ampliar: {item.alt}</span>
          </button>
        ))
      }
    </div>
  </div>

  <!-- Lightbox accesible con <dialog> nativo (mínimo JS). -->
  <dialog
    data-lightbox-dialog
    class="m-auto max-h-[92vh] max-w-[94vw] overflow-hidden rounded-[var(--radius-card)] bg-transparent p-0 backdrop:bg-tostado/80 backdrop:backdrop-blur-sm"
  >
    <div class="relative inline-block leading-none">
      <img
        data-lightbox-img
        src=""
        alt=""
        class="block h-auto w-auto max-h-[92vh] max-w-[94vw] rounded-[var(--radius-card)] object-contain shadow-[var(--shadow-warm-lg)]"
      />
      <button
        type="button"
        data-lightbox-close
        class="absolute right-3 top-3 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-crema/95 text-tostado shadow-[var(--shadow-warm-md)] backdrop-blur-sm transition-transform hover:scale-110"
      >
        <span class="sr-only">Cerrar</span>
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </button>
    </div>
  </dialog>
</section>

<script>
  const dialog = document.querySelector<HTMLDialogElement>(
    "[data-lightbox-dialog]"
  );
  const dialogImg = document.querySelector<HTMLImageElement>(
    "[data-lightbox-img]"
  );
  const closeBtn = document.querySelector<HTMLButtonElement>(
    "[data-lightbox-close]"
  );

  if (dialog && dialogImg) {
    document.querySelectorAll<HTMLButtonElement>("[data-lightbox]").forEach((btn) => {
      btn.addEventListener("click", () => {
        dialogImg.src = btn.dataset.src ?? "";
        dialogImg.alt = btn.dataset.alt ?? "";
        dialog.showModal();
      });
    });
    closeBtn?.addEventListener("click", () => dialog.close());
    // Cerrar al hacer click en el backdrop.
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });
  }
</script>
