---
import WhatsAppButton from "./ui/WhatsAppButton.astro";
import Stars from "./ui/Stars.astro";
import { wa, images, social, business } from "../data/site";
---

<section
  id="inicio"
  class="relative flex min-h-[100svh] items-center overflow-hidden"
>
  <!-- Imagen de fondo (LCP): carga prioritaria, con dimensiones para evitar CLS. -->
  <img
    src={images.hero.src}
    alt={images.hero.alt}
    width={images.hero.width}
    height={images.hero.height}
    fetchpriority="high"
    decoding="async"
    class="photo absolute inset-0 -z-10 h-full w-full object-cover"
  />
  <!-- Overlay cálido oscuro para legibilidad del texto. -->
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-b from-tostado/80 via-tostado/55 to-tostado/85"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute inset-0 -z-10 bg-[radial-gradient(120%_90%_at_50%_0%,transparent,rgba(43,29,22,0.35))]"
    aria-hidden="true"
  >
  </div>

  <div
    class="mx-auto w-full max-w-5xl px-4 pt-28 pb-16 text-center text-crema sm:px-6 lg:pt-32"
  >
    <p
      data-hero
      class="mb-5 inline-flex items-center gap-2 rounded-full border border-crema/25 bg-crema/10 px-4 py-1.5 text-xs font-medium uppercase tracking-[0.18em] backdrop-blur-sm sm:text-sm"
    >
      <svg class="h-4 w-4 text-ocre-300" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 23a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5.5 2.5-1 3.5-1 3.5.5-3-1.5-6-4.5-8 .5 3-1 4.5-2.5 6.5C6.7 9 5 11.4 5 16a7 7 0 0 0 7 7z" />
      </svg>
      {business.tagline} · {business.address.city}, Argentina
    </p>

    <h1
      class="tw-wrap mx-auto max-w-3xl text-4xl font-semibold leading-[1.05] sm:text-6xl lg:text-7xl"
    >
      <span data-tw-text
        ><span data-seg>Sabor salteño de verdad, </span><span
          data-seg
          data-accent
          class="text-ocre-300">desde {business.foundedYear}</span
        ></span
      >
      <span data-tw-render aria-hidden="true" class="tw-render"></span>
    </h1>

    <p
      data-hero
      class="mx-auto mt-6 max-w-2xl text-base text-crema/90 sm:text-xl"
    >
      Empanadas a cuchillo, locro, humita y vinos de altura, en el corazón de
      Salta. La cocina del norte argentino, como debe ser.
    </p>

    <div
      data-hero
      class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row"
    >
      <WhatsAppButton href={wa.reserva} label="Reservá por WhatsApp" size="lg" />
      <a
        href="#menu"
        class="cta group inline-flex items-center justify-center gap-2 rounded-full border border-crema/40 bg-crema/5 px-7 py-3.5 text-base font-semibold tracking-tight text-crema backdrop-blur-sm transition-[transform,background-color] duration-200 ease-[var(--ease-warm)] hover:-translate-y-0.5 hover:scale-[1.03] hover:bg-crema/15 active:scale-95 sm:text-lg"
      >
        Ver el menú
        <svg class="h-5 w-5 transition-transform duration-300 ease-[var(--ease-warm)] group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
    </div>

    <!-- Prueba social inmediata: vende sola, va arriba de todo. -->
    <ul
      data-hero
      class="mx-auto mt-12 flex max-w-3xl flex-wrap items-center justify-center gap-x-3 gap-y-3 text-sm font-medium text-crema/95 sm:text-base"
    >
      <li class="inline-flex items-center gap-1.5 rounded-full bg-tostado/40 px-4 py-2 backdrop-blur-sm">
        <Stars rating={1} total={1} class="text-ocre-300 text-[1rem]" />
        <strong class="font-semibold">{social.googleRating}</strong>
        <span class="text-crema/80">· {social.googleReviews} reseñas en Google</span>
      </li>
      <li class="inline-flex items-center gap-1.5 rounded-full bg-tostado/40 px-4 py-2 backdrop-blur-sm">
        <svg class="h-4 w-4 text-ocre-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 9a6 6 0 0 0 12 0V4H6zM6 4H3v2a3 3 0 0 0 3 3M18 4h3v2a3 3 0 0 1-3 3M9 21h6M12 17v4" />
        </svg>
        <span>{social.tripadvisor}</span>
      </li>
      <li class="inline-flex items-center gap-1.5 rounded-full bg-tostado/40 px-4 py-2 backdrop-blur-sm">
        <svg class="h-4 w-4 text-ocre-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z" /><circle cx="12" cy="10" r="3" />
        </svg>
        <span>{social.tripadvisorRank}</span>
      </li>
    </ul>
  </div>

  <!-- Indicador de scroll, decorativo. -->
  <div
    class="pointer-events-none absolute bottom-6 left-1/2 -translate-x-1/2 text-crema/60"
    aria-hidden="true"
  >
    <svg class="h-6 w-6 animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 5v14M6 13l6 6 6-6"></path>
    </svg>
  </div>
</section>

<script>
  // Efecto máquina de escribir del título del hero (medio rápido).
  // Solo corre si hay JS y el usuario no pidió reduced-motion (.anim-on).
  // El texto real queda en el DOM (data-tw-text) para SEO y lectores de pantalla.
  if (document.documentElement.classList.contains("anim-on")) {
    const textEl = document.querySelector<HTMLElement>("[data-tw-text]");
    const renderEl = document.querySelector<HTMLElement>("[data-tw-render]");

    if (textEl && renderEl) {
      try {
        // Construye la lista de caracteres conservando qué segmento es acento.
        const chars: { ch: string; accent: boolean }[] = [];
        textEl.querySelectorAll<HTMLElement>("[data-seg]").forEach((seg) => {
          const accent = seg.hasAttribute("data-accent");
          for (const ch of seg.textContent ?? "") chars.push({ ch, accent });
        });

        // Oculta la fuente visualmente (sigue ocupando espacio y la leen SR/SEO).
        textEl.style.opacity = "0";

        const caret = document.createElement("span");
        caret.className = "tw-caret";
        renderEl.appendChild(caret);

        let i = 0;
        let span: HTMLElement | null = null;
        let spanAccent: boolean | null = null;
        const SPEED = 42; // ms por caracter

        const type = () => {
          if (i >= chars.length) {
            window.setTimeout(() => caret.remove(), 1300);
            return;
          }
          const { ch, accent } = chars[i++];
          if (span === null || accent !== spanAccent) {
            span = document.createElement("span");
            if (accent) span.className = "text-ocre-300";
            renderEl.insertBefore(span, caret);
            spanAccent = accent;
          }
          span.appendChild(document.createTextNode(ch));
          window.setTimeout(type, SPEED);
        };

        // Pequeño retardo para que primero aparezca el "kicker" de arriba.
        window.setTimeout(type, 280);
      } catch {
        // Ante cualquier error, mostramos el título normal.
        textEl.style.opacity = "1";
        renderEl.textContent = "";
      }
    }
  }
</script>
