---
import SectionHeading from "./ui/SectionHeading.astro";
import WhatsAppButton from "./ui/WhatsAppButton.astro";
import { business, openingHours, wa } from "../data/site";

const fullAddress = `${business.address.street}, ${business.address.city}, ${business.address.region}`;
---

<section id="ubicacion" class="scroll-mt-20 bg-adobe-texture py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      kicker="Cómo llegar"
      title="Te esperamos en el corazón de Salta"
      subtitle="Estamos a un par de cuadras de la plaza. Reservá y vení a comer como en casa."
    />

    <div class="mt-12 grid gap-8 lg:grid-cols-2">
      <!-- Mapa -->
      <div
        data-reveal
        class="overflow-hidden rounded-[var(--radius-card)] shadow-[var(--shadow-warm-md)]"
      >
        <iframe
          src={business.mapsEmbedUrl}
          title={`Mapa de ubicación de ${business.name}`}
          width="600"
          height="450"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="h-full min-h-[340px] w-full border-0"
        ></iframe>
      </div>

      <!-- Datos -->
      <div data-reveal class="flex flex-col gap-6">
        <ul class="space-y-5">
          <li class="flex items-start gap-4">
            <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-terracota/10 text-terracota">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z" /><circle cx="12" cy="10" r="3" />
              </svg>
            </span>
            <div>
              <h3 class="font-semibold text-tostado">Dirección</h3>
              <p class="text-cerro">{fullAddress}</p>
            </div>
          </li>

          <li class="flex items-start gap-4">
            <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-terracota/10 text-terracota">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" />
              </svg>
            </span>
            <div class="w-full">
              <h3 class="font-semibold text-tostado">Horarios</h3>
              <ul class="mt-1 space-y-1 text-cerro">
                {
                  openingHours.map((h) => (
                    <li class="flex justify-between gap-4 text-sm sm:text-base">
                      <span>{h.day}</span>
                      <span class="font-medium text-tostado">{h.label}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </li>

          <li class="flex items-start gap-4">
            <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-terracota/10 text-terracota">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z" />
              </svg>
            </span>
            <div>
              <h3 class="font-semibold text-tostado">Teléfono</h3>
              <p class="text-cerro">
                <a href={`tel:${business.phoneHref}`} class="underline-offset-4 hover:text-terracota hover:underline">
                  {business.phoneDisplay}
                </a>
              </p>
            </div>
          </li>
        </ul>

        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href={business.mapsUrl}
            target="_blank"
            rel="noopener"
            class="cta group inline-flex items-center justify-center gap-2 rounded-full bg-cerro px-6 py-3 font-semibold text-crema transition-[transform,background-color] duration-200 ease-[var(--ease-warm)] hover:-translate-y-0.5 hover:scale-[1.03] hover:bg-cerro/90 active:scale-95"
          >
            <svg class="h-5 w-5 transition-transform duration-300 ease-[var(--ease-warm)] group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 11l19-9-9 19-2-8-8-2Z" />
            </svg>
            Cómo llegar
          </a>
          <WhatsAppButton href={wa.reserva} label="Reservá por WhatsApp" />
        </div>
      </div>
    </div>
  </div>
</section>
