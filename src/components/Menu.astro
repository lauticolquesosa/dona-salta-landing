---
import SectionHeading from "./ui/SectionHeading.astro";
import WhatsAppButton from "./ui/WhatsAppButton.astro";
import { dishes, wa, business } from "../data/site";

const menuHref =
  business.fullMenuUrl && !business.fullMenuUrl.startsWith("[")
    ? business.fullMenuUrl
    : "#menu";
// Sólo abrimos en una pestaña nueva los enlaces externos (http/https).
const menuIsExternal = /^https?:\/\//.test(menuHref);
---

<section id="menu" class="scroll-mt-20 bg-adobe-texture py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      kicker="El menú"
      title="Las especialidades de la casa"
      subtitle="Los sabores que hacen del norte argentino algo inolvidable. Esto es lo que no te podés perder."
    />

    <ul
      class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
    >
      {
        dishes.map((dish) => (
          <li
            data-reveal
            class="group flex flex-col overflow-hidden rounded-[var(--radius-card)] border border-[var(--color-linea)] bg-crema shadow-[var(--shadow-warm-sm)] transition-[transform,box-shadow] duration-300 ease-[var(--ease-warm)] hover:-translate-y-1 hover:shadow-[var(--shadow-warm-md)]"
          >
            <div class="relative aspect-[3/2] overflow-hidden">
              <img
                src={dish.img}
                alt={dish.alt}
                width="600"
                height="400"
                loading="lazy"
                decoding="async"
                class="photo h-full w-full object-cover transition-transform duration-500 ease-[var(--ease-warm)] group-hover:scale-105"
              />
              {dish.highlight && (
                <span class="absolute left-3 top-3 inline-flex items-center gap-1 rounded-full bg-terracota px-3 py-1 text-xs font-semibold text-crema">
                  <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                  </svg>
                  Imperdible
                </span>
              )}
            </div>
            <div class="flex flex-1 flex-col p-5">
              <div class="flex items-start justify-between gap-3">
                <h3 class="text-xl text-tostado">{dish.name}</h3>
                <span class="shrink-0 rounded-full bg-adobe px-3 py-1 text-sm font-semibold text-terracota-700">
                  {dish.price}
                </span>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-cerro">
                {dish.description}
              </p>
            </div>
          </li>
        ))
      }
    </ul>

    <div
      class="mt-12 flex flex-col items-center justify-center gap-3 sm:flex-row"
      data-reveal
    >
      <WhatsAppButton href={wa.menu} label="Reservá por WhatsApp" size="lg" />
      <a
        href={menuHref}
        target={menuIsExternal ? "_blank" : undefined}
        rel={menuIsExternal ? "noopener" : undefined}
        class="inline-flex items-center justify-center gap-2 rounded-full border border-terracota/40 px-7 py-3.5 text-base font-semibold text-terracota-700 transition-[transform,background-color] duration-200 ease-[var(--ease-warm)] hover:-translate-y-0.5 hover:bg-terracota hover:text-crema sm:text-lg"
      >
        Ver carta completa
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14 3h7v7M21 3l-9 9M21 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
