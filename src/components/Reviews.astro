---
import SectionHeading from "./ui/SectionHeading.astro";
import Stars from "./ui/Stars.astro";
import { reviews as curated, social } from "../data/site";
import snapshot from "../data/google-reviews.json";

/**
 * Reseñas REALES de Google, tomadas como snapshot (src/data/google-reviews.json)
 * con `node scripts/snapshot-reviews.mjs`. Se renderizan de forma 100% estática:
 * el sitio NO llama a Google en cada visita → costo $0.
 * Si el snapshot estuviera vacío, cae a las reseñas curadas de respaldo.
 */
type Card = {
  author: string;
  rating: number;
  text: string;
  dateLabel: string;
  photo: string | null;
  isGoogle: boolean;
};

const live = (snapshot.reviews ?? []) as Array<{
  author: string;
  rating: number;
  text: string;
  dateLabel: string;
  photo: string | null;
}>;

// Recorta textos muy largos para que las tarjetas queden parejas (2x2).
const truncate = (t: string, max = 320) =>
  t.length > max ? t.slice(0, max).replace(/\s+\S*$/, "") + "…" : t;

const display: Card[] = (
  live.length > 0
    ? live.map((r) => ({ ...r, text: truncate(r.text), isGoogle: true }))
    : curated.map((r) => ({
        author: r.author,
        rating: r.rating,
        text: r.text,
        dateLabel: r.source,
        photo: null,
        isGoogle: r.source === "Google",
      }))
).slice(0, 4); // 4 reseñas → grilla 2x2 prolija

const hasLive = live.length > 0;

// Cifras grandes: usamos los datos reales del snapshot si están disponibles.
const ratingBig = snapshot.rating ?? social.googleRating;
const totalBig =
  typeof snapshot.total === "number"
    ? new Intl.NumberFormat("es-AR").format(snapshot.total)
    : social.googleReviews;

const initial = (name: string) =>
  name.replace(/[^A-Za-zÁÉÍÓÚáéíóúÑñ]/g, "").charAt(0).toUpperCase() || "D";
---

<section id="resenas" class="scroll-mt-20 bg-tostado py-20 text-crema sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      kicker="Reseñas"
      title="Miles de comensales ya lo confirman"
      subtitle="No lo decimos nosotros: lo dicen las casi 30.000 personas que nos eligieron."
      tone="light"
    />

    <!-- Cifras grandes reiteradas -->
    <div
      data-reveal
      class="mx-auto mt-10 flex max-w-3xl flex-wrap items-center justify-center gap-x-10 gap-y-5 text-center"
    >
      <div>
        <p class="inline-flex items-center gap-1.5 font-[var(--font-display)] text-4xl font-semibold text-ocre-300" style="font-family: var(--font-display)">
          {ratingBig}
          <Stars rating={1} total={1} class="text-[1.9rem]" />
        </p>
        <p class="text-sm text-crema/70">{totalBig} reseñas en Google</p>
      </div>
      <div class="hidden h-12 w-px bg-crema/20 sm:block" aria-hidden="true"></div>
      <div>
        <p class="inline-flex items-center gap-2 font-[var(--font-display)] text-4xl font-semibold text-ocre-300" style="font-family: var(--font-display)">
          <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 9a6 6 0 0 0 12 0V4H6zM6 4H3v2a3 3 0 0 0 3 3M18 4h3v2a3 3 0 0 1-3 3M9 21h6M12 17v4" />
          </svg>
          2025
        </p>
        <p class="text-sm text-crema/70">Travelers' Choice · {social.tripadvisorRank}</p>
      </div>
      <div class="hidden h-12 w-px bg-crema/20 sm:block" aria-hidden="true"></div>
      <div>
        <p class="font-[var(--font-display)] text-4xl font-semibold text-ocre-300" style="font-family: var(--font-display)">
          {social.instagramFollowers}
        </p>
        <p class="text-sm text-crema/70">seguidores en Instagram</p>
      </div>
    </div>

    <ul class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        display.map((review) => (
          <li
            data-reveal
            class="flex flex-col rounded-[var(--radius-card)] bg-tostado-800 p-6 shadow-[var(--shadow-warm-md)] ring-1 ring-crema/5"
          >
            <Stars rating={review.rating} class="text-ocre text-[1.05rem]" />
            <blockquote class="mt-4 flex-1 text-base leading-relaxed text-crema/90">
              {review.text}
            </blockquote>
            <footer class="mt-5 flex items-center gap-3 border-t border-crema/10 pt-4">
              {review.photo ? (
                <img
                  src={review.photo}
                  alt=""
                  width="40"
                  height="40"
                  loading="lazy"
                  referrerpolicy="no-referrer"
                  class="h-10 w-10 shrink-0 rounded-full object-cover"
                />
              ) : (
                <span
                  class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-terracota font-[var(--font-display)] text-lg font-semibold text-crema"
                  style="font-family: var(--font-display)"
                  aria-hidden="true"
                >
                  {initial(review.author)}
                </span>
              )}
              <span class="flex flex-col">
                <cite class="not-italic font-semibold text-crema">{review.author}</cite>
                <span class="text-xs text-crema/60">
                  {review.isGoogle ? "vía Google" : `vía ${review.dateLabel}`}
                  {review.isGoogle && review.dateLabel ? ` · ${review.dateLabel}` : ""}
                </span>
              </span>
            </footer>
          </li>
        ))
      }
    </ul>

    {
      hasLive && (
        <p data-reveal class="mt-6 text-center text-xs text-crema/55">
          Reseñas reales de clientes en Google.
        </p>
      )
    }
  </div>
</section>
