---
import SectionHeading from "./ui/SectionHeading.astro";
import Stars from "./ui/Stars.astro";
import { reviews, social } from "../data/site";

const profileLinks = [
  { label: "Ver en Google", url: social.links.google },
  { label: "Ver en TripAdvisor", url: social.links.tripadvisor },
].filter((l) => l.url && !l.url.startsWith("["));
---

<section
  id="resenas"
  class="scroll-mt-20 bg-tostado py-20 text-crema sm:py-28"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      kicker="Reseñas"
      title="Miles de comensales ya lo confirman"
      subtitle="No lo decimos nosotros: lo dicen las casi 30.000 personas que nos eligieron."
      tone="light"
    />

    <!-- Cifras grandes reiteradas -->
    <div
      data-reveal
      class="mx-auto mt-10 flex max-w-3xl flex-wrap items-center justify-center gap-x-10 gap-y-5 text-center"
    >
      <div>
        <p class="inline-flex items-center gap-1.5 font-[var(--font-display)] text-4xl font-semibold text-ocre-300" style="font-family: var(--font-display)">
          {social.googleRating}
          <Stars rating={1} total={1} class="text-[1.9rem]" />
        </p>
        <p class="text-sm text-crema/70">{social.googleReviews} reseñas en Google</p>
      </div>
      <div class="hidden h-12 w-px bg-crema/20 sm:block" aria-hidden="true"></div>
      <div>
        <p class="inline-flex items-center gap-2 font-[var(--font-display)] text-4xl font-semibold text-ocre-300" style="font-family: var(--font-display)">
          <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 9a6 6 0 0 0 12 0V4H6zM6 4H3v2a3 3 0 0 0 3 3M18 4h3v2a3 3 0 0 1-3 3M9 21h6M12 17v4" />
          </svg>
          2025
        </p>
        <p class="text-sm text-crema/70">Travelers' Choice · {social.tripadvisorRank}</p>
      </div>
      <div class="hidden h-12 w-px bg-crema/20 sm:block" aria-hidden="true"></div>
      <div>
        <p class="font-[var(--font-display)] text-4xl font-semibold text-ocre-300" style="font-family: var(--font-display)">
          {social.instagramFollowers}
        </p>
        <p class="text-sm text-crema/70">seguidores en Instagram</p>
      </div>
    </div>

    <!-- Lista de reseñas. Render inicial = reseñas curadas (respaldo, no-JS, SEO).
         Si la API de Google responde, el script reemplaza esto por las MÁS NUEVAS. -->
    <ul
      data-reviews-list
      class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-2"
    >
      {
        reviews.map((review) => (
          <li
            data-reveal
            class="flex flex-col rounded-[var(--radius-card)] bg-tostado-800 p-6 shadow-[var(--shadow-warm-md)] ring-1 ring-crema/5"
          >
            <Stars rating={review.rating} class="text-ocre text-[1.05rem]" />
            <blockquote class="mt-4 flex-1 text-base leading-relaxed text-crema/90">
              {review.text}
            </blockquote>
            <footer class="mt-5 flex items-center gap-3 border-t border-crema/10 pt-4">
              <span
                class="flex h-10 w-10 items-center justify-center rounded-full bg-terracota font-[var(--font-display)] text-lg font-semibold text-crema"
                style="font-family: var(--font-display)"
                aria-hidden="true"
              >
                {review.author.replace(/[^A-Za-zÁÉÍÓÚáéíóúÑñ]/g, "").charAt(0) || "D"}
              </span>
              <span class="flex flex-col">
                <cite class="not-italic font-semibold text-crema">{review.author}</cite>
                <span class="text-xs text-crema/60">vía {review.source}</span>
              </span>
            </footer>
          </li>
        ))
      }
    </ul>

    <!-- Atribución a Google (se muestra solo cuando hay reseñas reales en vivo). -->
    <p
      data-reviews-source
      hidden
      class="mt-6 text-center text-xs text-crema/55"
    >
      Reseñas reales obtenidas de Google, actualizadas automáticamente.
    </p>

    {
      profileLinks.length > 0 && (
        <div data-reveal class="mt-10 flex flex-wrap items-center justify-center gap-4">
          {profileLinks.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 text-sm font-medium text-ocre-300 underline-offset-4 transition-colors hover:text-crema hover:underline"
            >
              {link.label}
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M7 17 17 7M7 7h10v10" />
              </svg>
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>

<script>
  // Trae las reseñas MÁS NUEVAS de Google desde el endpoint serverless y
  // reemplaza el respaldo curado. Si algo falla, se queda el respaldo.
  const STAR =
    "M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z";

  type LiveReview = {
    author: string;
    rating: number;
    text: string;
    relativeTime: string;
    photo: string | null;
    authorUrl: string | null;
  };

  function starsEl(rating: number): HTMLElement {
    const wrap = document.createElement("span");
    wrap.className = "inline-flex items-center gap-0.5 text-ocre text-[1.05rem]";
    wrap.setAttribute("role", "img");
    wrap.setAttribute("aria-label", `${rating} de 5 estrellas`);
    for (let i = 0; i < 5; i++) {
      const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
      svg.setAttribute("viewBox", "0 0 24 24");
      svg.setAttribute("fill", "currentColor");
      svg.setAttribute("aria-hidden", "true");
      svg.setAttribute("class", "h-[1em] w-[1em]" + (i < rating ? "" : " opacity-25"));
      const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
      path.setAttribute("d", STAR);
      svg.appendChild(path);
      wrap.appendChild(svg);
    }
    return wrap;
  }

  function initial(name: string): string {
    const m = name.replace(/[^A-Za-zÁÉÍÓÚáéíóúÑñ]/g, "");
    return m.charAt(0).toUpperCase() || "D";
  }

  // Construye una tarjeta usando textContent (a prueba de inyección de HTML).
  function card(r: LiveReview): HTMLLIElement {
    const li = document.createElement("li");
    li.className =
      "flex flex-col rounded-[var(--radius-card)] bg-tostado-800 p-6 shadow-[var(--shadow-warm-md)] ring-1 ring-crema/5";

    li.appendChild(starsEl(r.rating));

    const quote = document.createElement("blockquote");
    quote.className = "mt-4 flex-1 text-base leading-relaxed text-crema/90";
    quote.textContent = r.text;
    li.appendChild(quote);

    const footer = document.createElement("footer");
    footer.className =
      "mt-5 flex items-center gap-3 border-t border-crema/10 pt-4";

    if (r.photo) {
      const img = document.createElement("img");
      img.src = r.photo;
      img.alt = "";
      img.loading = "lazy";
      img.width = 40;
      img.height = 40;
      img.referrerPolicy = "no-referrer";
      img.className = "h-10 w-10 shrink-0 rounded-full object-cover";
      footer.appendChild(img);
    } else {
      const av = document.createElement("span");
      av.className =
        "flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-terracota text-lg font-semibold text-crema";
      av.style.fontFamily = "var(--font-display)";
      av.setAttribute("aria-hidden", "true");
      av.textContent = initial(r.author);
      footer.appendChild(av);
    }

    const meta = document.createElement("span");
    meta.className = "flex flex-col";
    const cite = document.createElement("cite");
    cite.className = "not-italic font-semibold text-crema";
    cite.textContent = r.author;
    const sub = document.createElement("span");
    sub.className = "text-xs text-crema/60";
    sub.textContent = r.relativeTime ? `vía Google · ${r.relativeTime}` : "vía Google";
    meta.append(cite, sub);
    footer.appendChild(meta);

    li.appendChild(footer);
    return li;
  }

  (async () => {
    const list = document.querySelector<HTMLUListElement>("[data-reviews-list]");
    if (!list) return;
    try {
      const res = await fetch("/api/reviews.json", { headers: { accept: "application/json" } });
      if (!res.ok) return;
      const data = await res.json();
      if (!data?.ok || !Array.isArray(data.reviews) || data.reviews.length === 0) return;

      list.replaceChildren(...data.reviews.map(card));

      const note = document.querySelector<HTMLElement>("[data-reviews-source]");
      if (note) note.hidden = false;
    } catch {
      /* Silencio: se mantiene el respaldo curado. */
    }
  })();
</script>
