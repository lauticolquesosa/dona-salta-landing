---
/**
 * Isla de animaciones. GSAP + ScrollTrigger SOLO para el reveal de scroll y la
 * entrada del hero. Se carga de forma diferida (el <script> de Astro es módulo
 * y se ejecuta async). Si el usuario pidió reduced-motion, el <html> no tiene
 * la clase .anim-on y acá no hacemos nada: el contenido ya está visible por CSS.
 */
---

<script>
  // Si no hay .anim-on (reduced-motion o sin JS), el contenido ya es visible.
  if (document.documentElement.classList.contains("anim-on")) {
    const run = async () => {
      const { gsap } = await import("gsap");
      const { ScrollTrigger } = await import("gsap/ScrollTrigger");
      gsap.registerPlugin(ScrollTrigger);

      // Entrada del hero: fade + rise escalonado, una sola vez.
      const heroEls = gsap.utils.toArray<HTMLElement>("[data-hero]");
      if (heroEls.length) {
        gsap.to(heroEls, {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: "power2.out",
          stagger: 0.12,
          delay: 0.1,
        });
      }

      // Reveals al hacer scroll, escalonados por lote (grillas incluidas).
      ScrollTrigger.batch("[data-reveal]", {
        start: "top 88%",
        once: true,
        onEnter: (batch) =>
          gsap.to(batch, {
            opacity: 1,
            y: 0,
            duration: 0.7,
            ease: "power2.out",
            stagger: 0.1,
            overwrite: true,
          }),
      });

      // Recalcular posiciones cuando fuentes/imágenes terminan de cargar.
      window.addEventListener("load", () => ScrollTrigger.refresh());
    };

    // Conteo ascendente de las estadísticas cuando entran en pantalla.
    const countUps = () => {
      const els = document.querySelectorAll<HTMLElement>("[data-countup]");
      if (!els.length) return;
      const nf = new Intl.NumberFormat("es-AR");

      const animate = (el: HTMLElement) => {
        const raw = (el.textContent ?? "").trim();
        const suffix = raw.endsWith("+") ? "+" : "";
        const num = raw.replace(/\+$/, "");
        const lastPart = num.includes(".") ? num.split(".").pop()! : "";
        const isDecimal = num.includes(".") && lastPart.length <= 2;
        const target = isDecimal
          ? parseFloat(num)
          : parseInt(num.replace(/\./g, ""), 10);
        if (!isFinite(target)) return;

        const DURATION = 1400;
        const start = performance.now();
        const tick = (now: number) => {
          const p = Math.min((now - start) / DURATION, 1);
          const eased = 1 - Math.pow(1 - p, 3); // easeOutCubic
          const val = target * eased;
          el.textContent = isDecimal
            ? val.toFixed(lastPart.length)
            : nf.format(Math.round(val)) + suffix;
          if (p < 1) requestAnimationFrame(tick);
          else el.textContent = raw; // valor exacto final
        };
        requestAnimationFrame(tick);
      };

      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              animate(e.target as HTMLElement);
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.6 }
      );
      els.forEach((el) => io.observe(el));
    };

    // Los <script> de Astro son módulos (defer): corren tras parsear el DOM.
    // Arrancamos enseguida para que el hero no quede oculto.
    run();
    countUps();
  }
</script>
