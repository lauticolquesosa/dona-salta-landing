---
import Stars from "./ui/Stars.astro";
import { social } from "../data/site";

const items = [
  {
    value: social.googleRating,
    star: true,
    label: `${social.googleReviews} reseñas en Google`,
  },
  {
    value: social.tripadvisorReviews,
    label: "reseñas · Travelers' Choice 2025",
  },
  {
    value: social.instagramFollowers,
    label: `seguidores en Instagram`,
  },
  {
    value: social.facebookRating,
    star: true,
    label: "valoración en Facebook",
  },
];
---

<section
  aria-label="Reconocimientos y prueba social"
  class="border-y border-tostado/10 bg-adobe-texture"
>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <ul
      class="grid grid-cols-2 gap-x-4 gap-y-6 text-center md:grid-cols-4"
    >
      {
        items.map((item) => (
          <li data-reveal class="flex flex-col items-center">
            <span class="inline-flex items-center gap-1 font-[var(--font-display)] text-3xl font-semibold text-terracota sm:text-4xl" style="font-family: var(--font-display)">
              {item.value}
              {item.star && <Stars rating={1} total={1} class="text-ocre text-[1.6rem]" />}
            </span>
            <span class="mt-1 max-w-[14rem] text-sm leading-snug text-cerro">
              {item.label}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
