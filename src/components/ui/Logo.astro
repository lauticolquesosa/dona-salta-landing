---
/**
 * Logo de marca (wordmark real "Doña Salta").
 * Se optimiza con el pipeline de imágenes de Astro (genera WebP liviano y
 * srcset @2x). El amarillo con contorno negro funciona sobre fondo oscuro
 * (hero/footer) y claro (header con scroll) sin necesidad de variantes.
 */
import { Image } from "astro:assets";
import logo from "../../assets/logo-dona-salta.png";

interface Props {
  class?: string;
  /** Carga prioritaria (true en el header, que es LCP-adyacente). */
  eager?: boolean;
}
const { class: extra = "", eager = false } = Astro.props;
---

<Image
  src={logo}
  alt="Doña Salta — cocina regional salteña"
  width={300}
  densities={[1, 2]}
  loading={eager ? "eager" : "lazy"}
  class:list={["block w-auto", extra]}
/>
