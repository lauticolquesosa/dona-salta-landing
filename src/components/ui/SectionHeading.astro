---
/** Encabezado de sección consistente: kicker + título + bajada opcional. */
interface Props {
  kicker?: string;
  title: string;
  subtitle?: string;
  align?: "center" | "left";
  tone?: "dark" | "light";
}
const {
  kicker,
  title,
  subtitle,
  align = "center",
  tone = "dark",
} = Astro.props;

const alignCls = align === "center" ? "text-center mx-auto" : "text-left";
const titleColor = tone === "light" ? "text-crema" : "text-tostado";
const subColor = tone === "light" ? "text-crema/85" : "text-cerro";
---

<div class:list={["max-w-2xl", alignCls]} data-reveal>
  {
    kicker && (
      <p class="mb-3 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-terracota">
        <span class="h-px w-6 bg-ocre" aria-hidden="true" />
        {kicker}
      </p>
    )
  }
  <h2 class:list={["text-3xl sm:text-4xl lg:text-5xl", titleColor]}>
    {title}
  </h2>
  {
    subtitle && (
      <p class:list={["mt-4 text-base sm:text-lg", subColor]}>{subtitle}</p>
    )
  }
</div>
