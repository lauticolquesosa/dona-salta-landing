---
/** Estrellas de rating como SVG (sin emojis). Tamaño vía font-size (1em). */
interface Props {
  rating?: number;
  total?: number;
  class?: string;
}
const { rating = 5, total = 5, class: extra = "" } = Astro.props;
const star =
  "M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z";
---

<span
  class:list={["inline-flex items-center gap-0.5", extra]}
  role="img"
  aria-label={`${rating} de ${total} estrellas`}
>
  {
    Array.from({ length: total }).map((_, i) => (
      <svg
        class:list={["h-[1em] w-[1em]", i < rating ? "" : "opacity-25"]}
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d={star} />
      </svg>
    ))
  }
</span>
