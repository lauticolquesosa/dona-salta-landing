---
/**
 * CTA reutilizable de WhatsApp (acción principal de conversión).
 * Variantes de estilo y tamaño; siempre abre el deep link wa.me.
 */
interface Props {
  href: string;
  label?: string;
  variant?: "primary" | "ghost" | "light" | "onColor";
  size?: "md" | "lg";
  class?: string;
  pulse?: boolean;
}

const {
  href,
  label = "Reservá por WhatsApp",
  variant = "primary",
  size = "md",
  class: extra = "",
  pulse = false,
} = Astro.props;

const base =
  "group inline-flex items-center justify-center gap-2.5 rounded-full font-semibold tracking-tight transition-[transform,background-color,box-shadow,color] duration-200 ease-[var(--ease-warm)] hover:-translate-y-0.5 active:translate-y-0";

const sizes = {
  md: "px-5 py-2.5 text-sm sm:text-base",
  lg: "px-7 py-3.5 text-base sm:text-lg",
};

const variants = {
  primary:
    "bg-terracota text-crema shadow-[var(--shadow-warm-md)] hover:bg-terracota-700 hover:shadow-[var(--shadow-warm-lg)]",
  onColor:
    "bg-crema text-terracota-700 shadow-[var(--shadow-warm-md)] hover:bg-white hover:shadow-[var(--shadow-warm-lg)]",
  light:
    "bg-white/95 text-tostado shadow-[var(--shadow-warm-sm)] hover:bg-white",
  ghost:
    "border border-tostado/25 bg-transparent text-tostado hover:bg-tostado hover:text-crema",
};
---

<a
  href={href}
  target="_blank"
  rel="noopener"
  class:list={[base, sizes[size], variants[variant], pulse && "wa-pulse", extra]}
>
  <svg
    class="h-5 w-5 shrink-0 transition-transform duration-200 group-hover:scale-110"
    viewBox="0 0 24 24"
    fill="currentColor"
    aria-hidden="true"
  >
    <path
      d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.509 5.26l-.999 3.648 3.738-.979zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.29.173-1.414z"
    ></path>
  </svg>
  <span>{label}</span>
</a>
