---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import ScrollAnimations from "../components/ScrollAnimations.astro";
import WhatsAppButton from "../components/ui/WhatsAppButton.astro";
import { fullMenu, menuNote, wa, business } from "../data/site";
---

<BaseLayout
  title="La carta — Doña Salta | Menú completo de cocina regional salteña"
  description="Carta completa de Doña Salta: empanadas salteñas, locro, humita, tamales, pastas, cabrito, minutas, postres regionales y vinos de altura de los Valles Calchaquíes."
>
  <Header />
  <main id="contenido">
    <!-- Encabezado de la carta -->
    <section class="bg-tostado text-crema">
      <div class="guarda" aria-hidden="true"></div>
      <div class="mx-auto max-w-7xl px-4 pb-16 pt-[calc(var(--header-h)+3.5rem)] sm:px-6 lg:px-8">
        <a
          href="/#menu"
          class="inline-flex items-center gap-2 text-sm font-medium text-crema/70 transition-colors hover:text-crema"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7"></path>
          </svg>
          Volver al inicio
        </a>
        <p class="mt-8 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-ocre-300">
          <span class="h-px w-6 bg-ocre" aria-hidden="true"></span>
          {business.name}
        </p>
        <h1 class="mt-3 text-4xl text-crema sm:text-5xl lg:text-6xl">La carta completa</h1>
        <p class="mt-4 max-w-2xl text-base text-crema/80 sm:text-lg">
          El sabor auténtico del norte argentino. Cocina regional salteña, pastas
          caseras, parrilla y una bodega de altura de los Valles Calchaquíes.
        </p>
        <p class="mt-4 text-sm text-crema/60">{menuNote}</p>
      </div>
    </section>

    <!-- Categorías de la carta -->
    <section class="bg-adobe-texture py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="gap-x-12 [column-gap:3rem] lg:columns-2">
          {
            fullMenu.map((cat) => (
              <div
                data-reveal
                class="mb-10 break-inside-avoid rounded-[var(--radius-card)] border border-[var(--color-linea)] bg-crema p-6 shadow-[var(--shadow-warm-sm)] sm:p-7"
              >
                <div class="mb-5 flex items-baseline justify-between gap-3 border-b border-[var(--color-linea)] pb-3">
                  <h2 class="text-2xl text-tostado sm:text-3xl">{cat.title}</h2>
                  {cat.note && (
                    <span class="shrink-0 text-xs font-semibold uppercase tracking-wide text-terracota-700">
                      {cat.note}
                    </span>
                  )}
                </div>
                <ul class="space-y-3.5">
                  {cat.items.map((item) => (
                    <li class="flex items-baseline gap-3">
                      <span class="text-tostado">
                        {item.name}
                        {item.note && (
                          <span class="ml-1.5 text-xs italic text-cerro-300">
                            ({item.note})
                          </span>
                        )}
                      </span>
                      <span class="mx-1 h-px flex-1 translate-y-[-2px] border-b border-dotted border-[var(--color-linea)]" aria-hidden="true" />
                      <span class="shrink-0 font-semibold text-terracota-700">
                        {item.price}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>

        <!-- Nota + CTA -->
        <div
          class="mt-6 flex flex-col items-center gap-5 rounded-[var(--radius-card)] border border-[var(--color-linea)] bg-crema/70 px-6 py-10 text-center"
          data-reveal
        >
          <p class="text-sm text-cerro">
            Los precios pueden variar. Consultá la disponibilidad del día por WhatsApp.
          </p>
          <WhatsAppButton href={wa.menu} label="Reservá una mesa" size="lg" />
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppFloat />
  <ScrollAnimations />
</BaseLayout>
